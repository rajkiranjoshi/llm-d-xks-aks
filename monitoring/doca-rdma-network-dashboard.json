        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HCA Activity Heatmap",
      "type": "row"
    },
    {
      "title": "TX Bandwidth per HCA",
      "description": "Transmit rate per HCA per node. Bright = actively sending. In P/D disagg, prefill nodes will be TX-heavy.",
      "type": "timeseries",
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "sortBy": "Max", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(port_xmit_data{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) * 4",
          "legendFormat": "{{source}} / {{hca}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RX Bandwidth per HCA",
      "description": "Receive rate per HCA per node. Bright = actively receiving. In P/D disagg, decode nodes will be RX-heavy.",
      "type": "timeseries",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "sortBy": "Max", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(port_rcv_data{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) * 4",
          "legendFormat": "{{source}} / {{hca}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 101,
      "title": "Per-Node TX vs RX (stacked per HCA)",
      "type": "row"
    },
    {
      "title": "TX vs RX — $node_repeat",
      "description": "TX (positive/up) vs RX (negative/down) per HCA. One panel per node.",
      "type": "timeseries",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "repeat": "node_repeat",
      "repeatDirection": "h",
      "maxPerRow": 2,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": true,
            "axisLabel": "RX ↓  /  ↑ TX",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 40,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "sortBy": "Max", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(port_xmit_data{source=~\"$node_repeat\", hca=~\"$hca\"}[$__rate_interval]) * 4",
          "legendFormat": "TX {{hca}}",
          "refId": "TX"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "-rate(port_rcv_data{source=~\"$node_repeat\", hca=~\"$hca\"}[$__rate_interval]) * 4",
          "legendFormat": "RX {{hca}}",
          "refId": "RX"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "HCA Utilization Snapshot",
      "type": "row"
    },
    {
      "title": "Current TX Rate per HCA",
      "description": "Instantaneous transmit rate. Verify all 8 HCAs are active.",
      "type": "bargauge",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" },
          "unit": "Bps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-blue", "value": null },
              { "color": "dark-green", "value": 1000000 },
              { "color": "dark-yellow", "value": 1000000000 },
              { "color": "dark-red", "value": 10000000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color",
        "namePlacement": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(port_xmit_data{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) * 4",
          "legendFormat": "{{source}} / {{hca}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Current RX Rate per HCA",
      "description": "Instantaneous receive rate. Verify all 8 HCAs are active.",
      "type": "bargauge",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" },
          "unit": "Bps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-blue", "value": null },
              { "color": "dark-green", "value": 1000000 },
              { "color": "dark-yellow", "value": 1000000000 },
              { "color": "dark-red", "value": 10000000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color",
        "namePlacement": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(port_rcv_data{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) * 4",
          "legendFormat": "{{source}} / {{hca}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 103,
      "title": "Packet Rates",
      "type": "row"
    },
    {
      "title": "TX Packets/s per HCA",
      "type": "timeseries",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "pps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "sortBy": "Max", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(port_xmit_packets{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval])",
          "legendFormat": "{{source}} / {{hca}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RX Packets/s per HCA",
      "type": "timeseries",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "pps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "sortBy": "Max", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(port_rcv_packets{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval])",
          "legendFormat": "{{source}} / {{hca}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 104,
      "title": "Errors & Port Health",
      "type": "row"
    },
    {
      "title": "Total Error Rate",
      "description": "Sum of all IB error counters across selected nodes and HCAs. Should be 0.",
      "type": "stat",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(port_rcv_errors{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) + rate(port_xmit_discards{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) + rate(port_rcv_constraint_errors{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) + rate(port_xmit_constraint_errors{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]) + rate(symbol_error{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval]))",
          "legendFormat": "errors/s",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Active IB Ports",
      "description": "Number of IB ports in Active state (state=4).",
      "type": "stat",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(ib_port_state{source=~\"$node\", hca=~\"$hca\"} == 4)",
          "legendFormat": "active ports",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "IB Port State",
      "description": "Per-HCA port state: 4=Active, 1=Down.",
      "type": "table",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 42 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "4": { "text": "Active", "color": "green" } } },
                  { "type": "value", "options": { "1": { "text": "Down", "color": "red" } } },
                  { "type": "value", "options": { "2": { "text": "Init", "color": "yellow" } } },
                  { "type": "value", "options": { "3": { "text": "Armed", "color": "orange" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "__name__" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "data_type" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "endpoint" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "instance" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "job" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "namespace" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "pod" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "port" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "service" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [ { "displayName": "source", "desc": false } ]
      },
      "transformations": [
        { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "source" }, { "field": "hca" } ] } }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "ib_port_state{source=~\"$node\", hca=~\"$hca\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "title": "Link Errors Rate",
      "description": "Rate of link_downed and link_error_recovery events.",
      "type": "timeseries",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(link_downed{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval])",
          "legendFormat": "link_downed {{source}}/{{hca}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(link_error_recovery{source=~\"$node\", hca=~\"$hca\"}[$__rate_interval])",
          "legendFormat": "link_error_recovery {{source}}/{{hca}}",
          "refId": "B"
        }
      ]
    }
